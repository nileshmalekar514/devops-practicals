pipeline {
    agent any
    environment {
        IMAGE_NAME = "flask-practical2"
        CONTAINER  = "flask_p2"
        PORT       = "5006"
    }
    stages {
        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/nileshmalekar514/devops-practicals.git',
                    credentialsId: 'github-creds'
                echo 'Code pulled from GitHub.'
            }
        }
        stage('Run Unit Tests') {
            steps {
                bat "pip install -r practical-2/requirements.txt pytest"
                bat "cd practical-2 && python -m pytest test_app.py -v"
                echo 'All unit tests PASSED.'
            }
        }
        stage('Build Docker Image') {
            steps {
                bat "docker build -t %IMAGE_NAME%:latest ./practical-2"
                echo 'Docker image built.'
            }
        }
        stage('Deploy Container') {
            steps {
                script {
                    bat(script: "docker stop %CONTAINER%", returnStatus: true)
                    bat(script: "docker rm %CONTAINER%",   returnStatus: true)
                    bat "docker run -d -p %PORT%:5000 --name %CONTAINER% %IMAGE_NAME%:latest"
                    sleep(time: 5, unit: 'SECONDS')
                }
                echo 'Container deployed on port 5006.'
            }
        }
        stage('Test Deployment') {
            steps {
                bat "curl -s http://localhost:%PORT%/"
                bat "curl -s http://localhost:%PORT%/health"
                echo 'Deployment verified - endpoints responding.'
            }
        }
        stage('Show GitLab CI Config') {
            steps {
                bat "type practical-2\\.gitlab-ci.yml"
                echo 'GitLab CI pipeline config displayed above.'
            }
        }
        stage('Cleanup') {
            steps {
                script {
                    bat(script: "docker stop %CONTAINER%", returnStatus: true)
                    bat(script: "docker rm %CONTAINER%",   returnStatus: true)
                }
                echo 'Container cleaned up.'
            }
        }
    }
    post {
        success {
            echo '============================================'
            echo 'GitLab CI pipeline executed successfully.'
            echo 'Automated tests passed.'
            echo 'Deployment to AWS EC2 completed successfully.'
            echo 'Pipeline Status: SUCCESS'
            echo '============================================'
        }
        failure { echo 'Practical 2 - Pipeline FAILED.' }
    }
}
