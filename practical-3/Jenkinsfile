pipeline {
    agent any
    environment {
        IMAGE_NAME = "flask-practical3"
        CONTAINER  = "flask_p3"
        PORT       = "5007"
    }
    stages {
        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/nileshmalekar514/devops-practicals.git',
                    credentialsId: 'github-creds'
                echo 'Code pulled from GitHub.'
            }
        }
        stage('Run Unit Tests') {
            steps {
                bat "pip install -r practical-3/requirements.txt pytest"
                bat "cd practical-3 && python -m pytest test_app.py -v"
                echo 'All unit tests PASSED.'
            }
        }
        stage('Show GitHub Actions Workflow') {
            steps {
                bat "type .github\\workflows\\ci.yml"
                echo 'GitHub Actions workflow displayed above - triggers on PR, runs tests, notifies Slack.'
            }
        }
        stage('Build Docker Image') {
            steps {
                bat "docker build -t %IMAGE_NAME%:latest ./practical-3"
                echo 'Docker image built.'
            }
        }
        stage('Test Container') {
            steps {
                script {
                    bat(script: "docker stop %CONTAINER%", returnStatus: true)
                    bat(script: "docker rm %CONTAINER%",   returnStatus: true)
                    bat "docker run -d -p %PORT%:5000 --name %CONTAINER% %IMAGE_NAME%:latest"
                    sleep(time: 5, unit: 'SECONDS')
                    bat "curl -s http://localhost:%PORT%/"
                    bat "curl -s http://localhost:%PORT%/health"
                }
                echo 'Container endpoints verified.'
            }
        }
        stage('Cleanup') {
            steps {
                script {
                    bat(script: "docker stop %CONTAINER%", returnStatus: true)
                    bat(script: "docker rm %CONTAINER%",   returnStatus: true)
                }
                echo 'Container cleaned up.'
            }
        }
    }
    post {
        success { echo 'Practical 3 - GitHub Actions + Unit Tests pipeline PASSED!' }
        failure { echo 'Practical 3 - Pipeline FAILED.' }
    }
}
