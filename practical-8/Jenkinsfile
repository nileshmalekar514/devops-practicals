pipeline {
    agent any
    stages {
        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/nileshmalekar514/devops-practicals.git',
                    credentialsId: 'github-creds'
                echo 'Code pulled from GitHub.'
            }
        }
        stage('Start Minikube') {
            steps {
                script {
                    bat(script: "minikube start --driver=docker", returnStatus: true)
                    bat(script: "minikube status", returnStatus: true)
                }
                echo 'Minikube cluster ready.'
            }
        }
        stage('Load Image') {
            steps {
                bat "docker build -t flask-practical4:latest ./practical-4"
                bat "minikube image load flask-practical4:latest"
                echo 'Image ready in Minikube.'
            }
        }
        stage('Apply ConfigMap') {
            steps {
                bat "kubectl apply -f practical-8/configmap.yaml"
                bat "kubectl get configmap app-config"
                bat "kubectl describe configmap app-config"
                echo 'ConfigMap created with app configuration.'
            }
        }
        stage('Deploy Pod') {
            steps {
                script {
                    bat(script: "kubectl delete pod flask-configmap-pod", returnStatus: true)
                    bat "kubectl apply -f practical-8/pod.yaml"
                    sleep(time: 15, unit: 'SECONDS')
                    bat "kubectl get pod flask-configmap-pod"
                }
                echo 'Pod deployed with ConfigMap injected as env vars.'
            }
        }
        stage('Verify Injection') {
            steps {
                bat "kubectl describe pod flask-configmap-pod"
                echo 'ConfigMap values verified in pod.'
            }
        }
    }
    post {
        success { echo 'Practical 8 - Kubernetes ConfigMap pipeline PASSED!' }
        failure { echo 'Practical 8 - Pipeline FAILED.' }
    }
}
